@page
@model anahged.Pages.AdministrationModel
@{
    ViewData["Title"] = "Administration ⚙️";
    Layout = "_Layout"; // Utilisez votre layout existant
}


@section Styles {
    <link href="~/css/administration.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/importVille.css"/>
    <link rel="stylesheet" href="~/css/operation.css"/>
}
<!-- Toast de succès -->
<div class="toast-container position-fixed top-0 start-50 translate-middle-x p-3" style="z-index: 1100;">
    <div id="successToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header bg-success text-white">
            <strong class="me-auto">Succès</strong>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body" id="successToastMessage">
            <!-- Le message sera injecté dynamiquement ici -->
        </div>
    </div>
</div>
<div class="container-fluid">
    <h1 class="h3 mb-4">Administration <i class="bi bi-gear-fill"></i></h1>
    <div class="admin-container">
        <!-- Menu vertical d'administration -->
        <div class="admin-sidebar">
            <ul class="admin-menu">
                <li><a href="#" class="admin-menu-link active" data-target="dashboard"><i class="bi bi-speedometer2"></i> Tableau de bord</a></li>
                <li><a href="#" class="admin-menu-link" data-target="roles"><i class="bi bi-shield-check"></i> Gestion des rôles</a></li>
                <li><a href="#" class="admin-menu-link" data-target="users"><i class="bi bi-people-fill"></i> Gestion des utilisateurs</a></li>
                <li><a href="#" class="admin-menu-link" data-target="operations"><i class="bi bi-people-fill"></i>Opérations</a></li>
                <li><a href="#" class="admin-menu-link" data-target="villes"><i class="bi bi-people-fill"></i>Villes</a></li>
                <li><a href="#" class="admin-menu-link" data-target="statuts"><i class="bi bi-people-fill"></i> Gestion des statuts</a></li>
                <li><a href="#" class="admin-menu-link" data-target="settings"><i class="bi bi-sliders"></i> Paramètres système</a></li>
                <li><a href="#" class="admin-menu-link" data-target="logs"><i class="bi bi-clipboard-check"></i> Journalisation</a></li>
            </ul>
        </div>
        
        <!-- Contenu de l'administration -->
        <div class="admin-content">
            <!-- Tableau de bord -->
            <div id="dashboard" class="admin-section active">
                @* <h2 class="mb-4">Tableau de bord d'administration</h2> *@
                <div class="row">
                    <div class="col-md-3">
                        <div class="admin-card">
                            <div class="admin-stat">
                                <i class="bi bi-people-fill"></i>
                                <h3>156</h3>
                                <p>Utilisateurs</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="admin-card">
                            <div class="admin-stat">
                                <i class="bi bi-shield-check"></i>
                                <h3>8</h3>
                                <p>Rôles</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="admin-card">
                            <div class="admin-stat">
                                <i class="bi bi-archive-fill"></i>
                                <h3>2,548</h3>
                                <p>Archives</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="admin-card">
                            <div class="admin-stat">
                                <i class="bi bi-clock-history"></i>
                                <h3>12</h3>
                                <p>Activité récente</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Gestion des rôles -->
            <div id="roles" class="admin-section">
                <h2 class="mb-4">Gestion des rôles</h2>
                
                <div class="admin-card">
                    <div class="admin-card-header">
                        <span>Liste des rôles</span>
                        <button class="btn text-white btn-sm" style="background: linear-gradient(135deg, #10b981 0%, #374151 100%);">
                            <i class="bi bi-plus-circle"></i> Nouveau rôle
                        </button>
                    </div>
                    <div class="admin-card-body">
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>N°</th>
                                        <th>Description R.</th>
                                        <th>Perm. Vpl & adp</th>
                                        <th>Perm. carte</th>
                                        <th>Perm. Vpl Adp carte</th>
                                        <th>Permi. Administrateur</th>
                                        <th>Perm. Superviseur</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var role in Model.RoleList)
                                    {
                                        <tr>
                                            <td>@role.GroupeId</td>
                                            <td>@role.NomGroupe</td>
                                            <td>
                                                @if (role.VplAdp == 1)
                                                {
                                                    <span class="badge bg-success">Oui</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Non</span>
                                                }
                                            </td>
                                            <td>
                                                @if (role.Carte == 1)
                                                {
                                                    <span class="badge bg-success">Oui</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Non</span>
                                                }
                                            </td>
                                            <td>
                                                @if (role.VpladpCarte == 1)
                                                {
                                                    <span class="badge bg-success">Oui</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Non</span>
                                                }
                                            </td>
                                            <td>
                                                @if (role.Administrateur == 1)
                                                {
                                                    <span class="badge bg-success">Oui</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Non</span>
                                                }
                                            </td>
                                            <td>
                                                @if (role.Superviseur == 1)
                                                {
                                                    <span class="badge bg-success">Oui</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Non</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Gestion des utilisateurs -->
             <div id="users" class="admin-section">
                <h2 class="mb-4">Gestion des utilisateurs</h2>
                
                <div class="admin-card">
                    <div class="admin-card-header">
                        <span>Liste des utilisateurs</span>
                        <button class="btn btn-sm text-white" style="background: linear-gradient(135deg, #10b981 0%, #374151 100%);" data-bs-toggle="modal" data-bs-target="#createUserModal">
                            <i class="bi bi-plus-circle"></i> Nouvel utilisateur
                        </button>
                    </div>
                    <div class="admin-card-body">
                        <!-- Barre de filtrage -->
                <div class="filter-container">
                        <div class="filter-input">
                            <input type="text" id="filterInput" class="form-control form-control-sm" placeholder="Filtrer par nom, prénom, email ou rôle...">
                        </div>
                        <div class="filter-stats">
                            <span id="filterStats" class="text-muted small">@Model.UserList.Count() utilisateur(s)</span>
                        </div>
                    </div>
                        <div class="table-responsive" style="max-height:40vh; overflow-y:auto;margin-top:0px;">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <tr>
                                            <th>Nom</th>
                                            <th>Prénoms</th>
                                            <th>Tél.</th>
                                            <th>Email</th>
                                            <th>Rôles</th>
                                            <th>Actif</th>
                                        </tr>
                                    </tr>
                                </thead>
                                <tbody id="userTableBody">
                                    @foreach (var user in Model.UserList)
                                    {
                                        <tr>
                                            <td>
                                              <!--  <a href="" class="" style="color:#10b981; text-decoration: none"></a> -->
                                                <span class="clickable-name" 
                                                    data-bs-toggle="modal" 
                                                    data-bs-target="#userModal"
                                                    data-user-id="@user.UserId"
                                                    data-nom="@user.NomUser"
                                                    data-contact="@user.Contact"
                                                    data-prenom="@user.PrenomUser"
                                                    data-email="@user.Email"
                                                    data-role="@user.GroupeId"      
                                                    data-actif="@user.Actif"
                                                    data-statuts="@(user.Userstatuts != null ? string.Join(",", user.Userstatuts.Select(s => s.IdStatut)) : "")">
                                                    @user.NomUser
                                                </span>
                                            </td>
                                            <td>@user.PrenomUser</td>
                                            <td>@user.Contact</td>
                                            <td>@user.Email</td>
                                            <td>@user.Groupe!.NomGroupe</td>
                                            <td>
                                                @if (user.Actif ==1)
                                                {
                                                    <span class="badge bg-success">Oui</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Non</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modal de modification utilisateur -->
            <div class="modal fade" id="userModal" tabindex="-1" aria-labelledby="userModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="userModalLabel">Modifier l'utilisateur</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <form id="userForm">
                                @Html.AntiForgeryToken()
                                <input type="hidden" id="userId">
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label for="nom" class="form-label required-field">Nom</label>
                                        <input type="text" class="form-control" id="nom" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="prenom" class="form-label required-field">Prénom</label>
                                        <input type="text" class="form-control" id="prenom" required>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label for="email" class="form-label required-field">Email</label>
                                        <input type="email" class="form-control" id="email" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="email" class="form-label required-field">Tél.</label>
                                        <input type="contact" class="form-control" id="contact" required>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label for="createPassword" class="form-label ">Mot de passe</label>
                                        <input type="password" class="form-control" id="createPasswordEdit" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="createConfirmPassword" class="form-label">Confirmer le mot de passe</label>
                                        <input type="password" class="form-control" id="createConfirmPasswordEdit" required>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label for="role" class="form-label required-field">Rôle</label>
                                        <select class="form-select" id="role" required>
                                            <option value="">Sélectionner un rôle</option>
                                            <!-- Ajoutez ici les options de rôle dynamiques si nécessaire -->
                                            @foreach (var role in Model.RoleList)
                                            {
                                                <option value="@role.GroupeId">@role.NomGroupe</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <!-- Checklist des statuts -->
                                        <label class="form-label">Statuts attribués</label>
                                        <div class="card border-1 bg-light" style="max-height: 200px; overflow-y: auto;">
                                            <div class="card-body p-2">
                                                @if (Model.StatutList != null && Model.StatutList.Any())
                                                {
                                                    int count = 1;
                                                    foreach (var statut in Model.StatutList)
                                                    {
                                                        <div class="form-check mb-1">
                                                            <input class="form-check-input user-statut-checkbox-edit" 
                                                                type="checkbox" 
                                                                value="@statut.IdStatut" 
                                                                id="userStatut-edit-@statut.IdStatut"
                                                                data-code="@statut.CodeStatut">
                                                            <label class="form-check-label small" for="userStatut-edit-@statut.IdStatut">
                                                                <strong>@statut.DescriptionStatut</strong>
                                                            </label>
                                                        </div>
                                                        count++;
                                                    }
                                                }
                                                else
                                                {
                                                    <div class="text-muted small">
                                                        Aucun statut disponible
                                                    </div>
                                                }
                                            </div>
                                            <div class="card-footer p-2 bg-transparent border-0">
                                                <div class="d-flex justify-content-between">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="checkAllUserStatutsEdit">
                                                        <label class="form-check-label small" for="checkAllUserStatutsEdit">
                                                            Tout sélectionner
                                                        </label>
                                                    </div>
                                                    <span class="badge bg-secondary" id="selectedStatutsCountEdit">0</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="actif" checked style="background-color:#10b981;">
                                        <label class="form-check-label" for="actif">Utilisateur actif</label>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn text-white" data-bs-dismiss="modal" style="background: #374151;">Annuler</button>
                            <button type="button" class="btn btn-danger" id="deleteUser">Supprimer</button>
                            <button type="button" class="btn text-white" id="saveUser" style="background: linear-gradient(135deg, #10b981 0%, #374151 100%);">Enregistrer</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modal de création d'utilisateur -->
            <div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="createUserModalLabel">Créer un nouvel utilisateur</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <form id="createUserForm">
                                @Html.AntiForgeryToken()
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label for="createNom" class="form-label required-field">Nom</label>
                                        <input type="text" class="form-control" id="createNom" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="createPrenom" class="form-label required-field">Prénom</label>
                                        <input type="text" class="form-control" id="createPrenom" required>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label for="createEmail" class="form-label required-field">Email</label>
                                        <input type="email" class="form-control" id="createEmail" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="createContact" class="form-label required-field">Tél.</label>
                                        <input type="contact" class="form-control" id="createContact" required>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label for="createPassword" class="form-label required-field">Mot de passe</label>
                                        <input type="password" class="form-control" id="createPassword" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="createConfirmPassword" class="form-label required-field">Confirmer le mot de passe</label>
                                        <input type="password" class="form-control" id="createConfirmPassword" required>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label for="createRole" class="form-label required-field">Rôle</label>
                                        <select class="form-select" id="createRole" required>
                                            <option value="">Sélectionner un rôle</option>
                                            @foreach (var role in Model.RoleList)
                                            {
                                                <option value="@role.GroupeId">@role.NomGroupe</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <!-- Checklist des statuts -->
                                        <label class="form-label">Statuts attribués</label>
                                        <div class="card border-1 bg-light" style="max-height: 200px; overflow-y: auto;">
                                            <div class="card-body p-2">
                                                @if (Model.StatutList != null && Model.StatutList.Any())
                                                {
                                                    int count = 1;
                                                    foreach (var statut in Model.StatutList)
                                                    {
                                                        <div class="form-check mb-1">
                                                            <input class="form-check-input user-statut-checkbox" 
                                                                type="checkbox" 
                                                                value="@statut.IdStatut" 
                                                                id="userStatut-@statut.IdStatut"
                                                                data-code="@statut.CodeStatut">
                                                            <label class="form-check-label small" for="userStatut-@statut.IdStatut">
                                                                <strong>@statut.DescriptionStatut</strong>
                                                            </label>
                                                        </div>
                                                        count++;
                                                    }
                                                }
                                                else
                                                {
                                                    <div class="text-muted small">
                                                        Aucun statut disponible
                                                    </div>
                                                }
                                            </div>
                                            <div class="card-footer p-2 bg-transparent border-0">
                                                <div class="d-flex justify-content-between">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="checkAllUserStatuts">
                                                        <label class="form-check-label small" for="checkAllUserStatuts">
                                                            Tout sélectionner
                                                        </label>
                                                    </div>
                                                    <span class="badge bg-secondary" id="selectedStatutsCount">0</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="createActif" checked style="background-color:#10b981;">
                                        <label class="form-check-label" for="actif">Utilisateur actif</label>
                                    </div>
                                </div>
                                
                                <!-- Champ caché pour stocker les IDs des statuts sélectionnés -->
                                <input type="hidden" id="selectedUserStatutIds" name="selectedUserStatutIds" />
                            </form>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn text-white" data-bs-dismiss="modal" style="background: #374151;">Annuler</button>
                            <button type="button" class="btn text-white" id="createUser" style="background: linear-gradient(135deg, #10b981 0%, #374151 100%);">Créer l'utilisateur</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Gestion des statuts -->
            @Html.AntiForgeryToken()
            <div id="statuts" class="admin-section">
                <h2 class="mb-4">Gestion des statuts</h2>      
                <div class="admin-card">
                    <div class="admin-card-header">
                        
                        <div class="d-flex gap-2 align-items-center">
                            <span>Liste des statuts</span>
                            <!-- Bouton Actions avec dropdown -->
                            <div class="dropdown">
                                <button class="btn btn-secondary btn-sm dropdown-toggle" type="button" 
                                        id="actionsDropdownStatuts" 
                                        data-bs-toggle="dropdown" 
                                        aria-expanded="false">
                                    Actions
                                </button>
                                <ul class="dropdown-menu" aria-labelledby="actionsDropdownStatuts">
                                    <li><a class="dropdown-item" href="#" id="deleteSelected">Supprimer la sélection</a></li>
                                </ul>
                            </div>
                        </div>
                        <button class="btn text-white btn-sm" data-bs-toggle="modal" data-bs-target="#createStatutModal" style="background: linear-gradient(135deg, #10b981 0%, #374151 100%);">
                            <i class="bi bi-plus-circle"></i> Nouveau statut
                        </button>
                    </div>
                    <div class="admin-card-body">
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th><input type="checkbox" id="selectAllCheckboxStatuts" style="cursor: pointer;" /></th>
                                        <th>N°</th>
                                        <th>Code</th>
                                        <th>Description</th>
                                        <th>Note</th>
                                    </tr>
                                </thead>
                                <tbody>
                                   <!-- Code pour afficher les statuts -->
                                    @{ int counter = 1; }
                                    @foreach (var statut in Model.StatutList)
                                    {
                                        <tr>
                                        <td><input type="checkbox" class="statut-checkbox" data-statut-id="@statut.IdStatut" /></td>
                                        <td>@counter</td>
                                        <td>
                                            <span class="clickable-name"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editStatutModal"
                                                data-statut-id="@statut.IdStatut"
                                                data-code-statut="@statut.CodeStatut"
                                                data-description-statut="@statut.DescriptionStatut"
                                                data-note-statut="@statut.NoteStatut">
                                                @statut.CodeStatut
                                            </span>

                                        </td>
                                        <td>@statut.DescriptionStatut</td>
                                        <td>@statut.NoteStatut</td>
                                        </tr>
                                        counter++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modale de création des statuts -->
            <div class="modal fade" id="createStatutModal" tabindex="-1" aria-labelledby="createStatutModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="createStatutModalLabel">Créer un nouveau statut</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <form id="createStatutForm">
                                @Html.AntiForgeryToken()
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label for="createCodeStatut" class="form-label required-field">Code</label>
                                        <input type="text" class="form-control" id="createCodeStatut" name="codeStatut" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="createDescriptionStatut" class="form-label required-field">Description</label>
                                        <input type="text" class="form-control" id="createDescriptionStatut" name="descriptionStatut" required>
                                    </div>
                                </div>                        
                                <div class="row mb-3">
                                    <div class="col-md-12">
                                        <label for="createNoteStatut" class="form-label">Note</label>
                                        <textarea class="form-control" id="createNoteStatut" name="noteStatut" rows="3"></textarea>
                                    </div>
                                </div>                     
                            </form>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn text-white" data-bs-dismiss="modal" style="background: #374151;">Annuler</button>
                            <button type="button" class="btn text-white" id="createStatut" style="background: linear-gradient(135deg, #10b981 0%, #374151 100%);">Créer statut</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modale de modification des statuts -->
            <div class="modal fade" id="editStatutModal" tabindex="-1" aria-labelledby="editStatutModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
