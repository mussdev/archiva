                            <button type="button" id="importSubmitBtn" class="btn text-white" disabled
                                    style="background: linear-gradient(135deg, #10b981 0%, #374151 100%);">
                                <i class="bi bi-upload me-2"></i>Importer les villes
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Toast pour les notifications -->
            <div class="toast-container">
                <div id="successToast" class="toast align-items-center text-white bg-success border-0" role="alert">
                    <div class="d-flex">
                        <div class="toast-body">
                            Utilisateur créé avec succès!
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                </div>
            </div>
            
            <!-- Paramètres système -->
            <div id="settings" class="admin-section">
                <h2 class="mb-4">Paramètres système</h2>
                
                <div class="admin-card">
                    <div class="admin-card-header">
                        Configuration de l'application
                    </div>
                    <div class="admin-card-body">
                        <form>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="appName" class="form-label">Nom de l'application</label>
                                    <input type="text" class="form-control" id="appName" value="ANAHGED">
                                </div>
                                <div class="col-md-6">
                                    <label for="maxFileSize" class="form-label">Taille maximale des fichiers (MB)</label>
                                    <input type="number" class="form-control" id="maxFileSize" value="100">
                                </div>
                            </div>
                            
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="backupFrequency" class="form-label">Fréquence de sauvegarde</label>
                                    <select class="form-select" id="backupFrequency">
                                        <option selected>Quotidienne</option>
                                        <option>Hebdomadaire</option>
                                        <option>Mensuelle</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label for="sessionTimeout" class="form-label">Délai d'expiration de session (minutes)</label>
                                    <input type="number" class="form-control" id="sessionTimeout" value="60">
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="maintenanceMode">
                                    <label class="form-check-label" for="maintenanceMode">
                                        Mode maintenance
                                    </label>
                                </div>
                            </div>
                            
                            <button type="submit" class="btn btn-primary">Enregistrer les paramètres</button>
                        </form>
                    </div>
                </div>
            </div>
            
            <!-- Journalisation -->
            
            <div class="mb-3">
                <div class="btn-group" role="group">
                    <button type="button" class="btn btn-outline-primary active" data-tab="all">Tous</button>
                    <button type="button" class="btn btn-outline-primary" data-tab="login">Connexions</button>
                    <button type="button" class="btn btn-outline-primary" data-tab="transactions">Historique ADP</button>
                    <button type="button" class="btn btn-outline-primary" data-tab="operations">Historique VPL</button>
                    <button type="button" class="btn btn-outline-primary" data-tab="villes">Historique CARTE</button>
                    <button type="button" class="btn btn-outline-primary" data-tab="validations">Historique validations</button>
                    <button type="button" class="btn btn-outline-primary" data-tab="errors">Erreurs</button>
                </div>
            </div>

            <!-- Tableau pour Tous les logs (colonies générales) -->
            <div id="tab-all" class="log-table-container active">
                <table class="table table-striped">
                    <thead>
                        <tr><th>Utilisateur</th><th>Date</th><th>Action</th><th>Catégorie</th></tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

            <!-- Tableau pour Connexions (mêmes colonnes, mais seulement les connexions) -->
            <div id="tab-login" class="log-table-container">
                <table class="table table-striped">
                    <thead><tr><th>Utilisateur</th><th>Date</th><th>Adresse IP</th><th>Statut</th></tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

            <!-- Tableau pour Historique  ADP (colonnes spécifiques) -->
            <div id="tab-transactions" class="log-table-container">
                <table class="table table-striped">
                    <thead>
                        <tr><th>ID Transaction</th><th>Utilisateur</th><th>Date</th><th>Montant</th><th>Type</th><th>Statut</th></tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

            <!-- Tableau pour Historique VPL (colonnes spécifiques) -->
            <div id="tab-transactionsvpl" class="log-table-container">
                <table class="table table-striped">
                    <thead>
                        <tr><th>ID Transaction</th><th>Utilisateur</th><th>Date</th><th>Montant</th><th>Type</th><th>Statut</th></tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

            <!-- Tableau pour Historique CARTE (colonnes spécifiques) -->
            <div id="tab-transactionscarte" class="log-table-container">
                <table class="table table-striped">
                    <thead>
                        <tr><th>ID Transaction</th><th>Utilisateur</th><th>Date</th><th>Montant</th><th>Type</th><th>Statut</th></tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

            <!-- Tableau pour Validations (colonnes spécifiques) -->
            <div id="tab-validations" class="log-table-container">
                <table class="table table-striped">
                    <thead>
                        <tr><th>Document</th><th>Validateur</th><th>Date validation</th><th>Commentaire</th><th>Statut</th></tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

            <!-- Tableau pour Erreurs -->
            <div id="tab-errors" class="log-table-container">
                <table class="table table-striped">
                    <thead>
                        <tr><th>Utilisateur</th><th>Date</th><th>Message d'erreur</th><th>Stack trace (optionnel)</th></tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/users.js"></script>
    <script src="~/js/importVille.js"></script>
    <script src="~/js/operation.js"></script>
    <script src="~/js/administration.js"></script>
}