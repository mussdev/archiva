@page
@model anahged.Pages.AdpListModel
@{
    ViewData["Title"] = "Liste Adp";
}

@section Styles {
    <link rel="stylesheet" href="~/css/adp.css"/>  
}


<!-- Afficher les messages de succès -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Afficher les messages d'erreur de validation -->
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div id="adp-list-page">
    <div class="d-flex align-items-center">
        <h3>ADP 📚</h3>
        <!-- Bouton Actions avec dropdown -->
        <div class="dropdown">
            <button class="btn btn-secondary dropdown-toggle" type="button" 
                    id="actionsDropdown" 
                    data-bs-toggle="dropdown" 
                    aria-expanded="false">
                Actions
            </button>
            <ul class="dropdown-menu" aria-labelledby="actionsDropdown">
                <li><a class="dropdown-item" href="#" id="exportSelected">Télécharger la sélection</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="#" id="deleteSelected">Supprimer la sélection</a></li>
            </ul>
        </div>
        <div class="ms-auto d-flex gap-2">
            <a class="text-white ms-auto underline btn" 
                asp-area=""
                asp-page="/ValidationsAdpVpl"
                style="background: linear-gradient(135deg, #e7b615 0%, #374151 100%);">
                Validations
            </a>
            @if(User.IsInRole("Administrateur")){
                <button type="button" class="btn text-white ms-auto" data-bs-toggle="modal" data-bs-target="#ajoutFichierModal"
                        style="background: linear-gradient(135deg, #10b981 0%, #374151 100%);">
                    Ajouter un fichier
                </button>
            }
        </div>
    </div>
    <form method="get" class="mt-3 mb-3">
        <div class="row g-2" style="border-bottom: 5px solid #ccc; padding-bottom:10px;">
            <div class="col">
                <input type="text" name="boite" class="form-control" placeholder="N° Boite">
            </div>
            <div class="col">
                <input type="text" name="code" class="form-control" placeholder="Code">
            </div>
            <div class="col">
                <input type="text" name="logement" class="form-control" placeholder="N° Logement">
            </div>
            <div class="col">
                <input type="text" name="client" class="form-control" placeholder="Client">
            </div>
            <div class="col">
                <input type="text" name="annee" class="form-control" placeholder="Annee">
            </div>
            <div class="col-auto">
                <button type="submit" class="btn text-white" style="background: linear-gradient(135deg, #10b981 0%, #374151 100%);">Rechercher</button>
            </div>
        </div>
    </form>

    @if (ViewData["MessageRecherche"] != null)
    {
        <p style="text-align: center; color:red">@ViewData["MessageRecherche"]</p>
    }
    else
    {
        // Afficher la liste de résultats
        <div class="filter-container">
            <div style="max-height:60vh; overflow-y:auto;margin-top:20px;">
                <div class="filter-input">
                    <input type="text" id="table-filter" class="form-control form-control-sm" placeholder="Filtrer par boite, code,n° logement, client, document ou ...">
                </div>
                <div class="filter-stats">
                    <span id="filterStats" class="text-muted small">@(Model.AdpList?.Count() ?? 0) fichier(s) trouvé(s)</span>
                </div>
                <table class="table mt-1">
                    <thead>
                        <tr>
                            <th style="font-size: 12px;"><input type="checkbox" id="selectAllCheckbox" style="cursor: pointer;" /></th>
                            <th style="font-size: 12px;">Document</th>
                            <th style="font-size: 12px;">Boite</th>
                            <th style="font-size: 12px;">Code</th>
                            <th style="font-size: 12px;">N° Dossier</th>
                            <th style="font-size: 12px;">Lgt.</th>
                            <th style="font-size: 12px;">Statut</th>
                            <th style="font-size: 12px;">Client</th>
                            <th style="font-size: 12px;">Profession clt.</th>
                            <th style="font-size: 12px;">Tél.</th>
                            <th style="font-size: 12px;">Adresse</th>
                            <th style="font-size: 12px;">Annee</th>
                            <th style="font-size: 12px;">Ville</th>
                            <th style="font-size: 12px;">Opération ou Commune</th>
                            <th style="font-size: 12px;">Date doc.</th>
                        </tr>
                    </thead>
                    <tbody id="adpTableBody">
                        @foreach (var adp in Model.AdpList)
                        {
                            <tr>
                                <td style="font-size: 12px;"><input type="checkbox" class="rowCheckbox" data-adp-id="@adp.IdAdp" style="cursor: pointer;"></td>
                                <td style="font-size: 12px;"> 
                                    <span class="clickable-name" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#adpModal"
                                        data-adp-id="@adp.IdAdp"
                                        data-document="@(string.IsNullOrEmpty(adp.Document) ? "" : char.ToUpper(adp.Document[0]) + adp.Document.Substring(1).ToLower())"
                                        data-contact="@adp.Contact"
                                        data-datedocument="@adp.DateDocument"
                                        data-annee="@adp.Annee"
                                        data-fonctions="@adp.Fonctions"
                                        data-client="@adp.Client"
                                        data-code="@adp.Code"
                                        data-id-ope="@adp.IdOpe"
                                        data-statut-id="@adp.DernierStatutAdpId"
                                        data-numDossier="@adp.NumDossierAdp"
                                        data-boite="@adp.Boite"
                                        data-logement="@adp.Logement"
                                        data-adresse="@adp.Adresse"
                                        data-communequartier="@adp.CommuneQuartier"
                                        data-ville="@adp.IdOpeNavigation?.IdVilleNavigation?.DescriptionVille"
                                        data-fichier="@(adp.Lien ??"")">
                                        @(string.IsNullOrEmpty(adp.Document) ? "" : char.ToUpper(adp.Document[0]) + adp.Document.Substring(1).ToLower())
                                    </span>
                                </td>
                                <td style="font-size: 12px;">@adp.Boite</td>
                                <td style="font-size: 12px;">@(string.IsNullOrWhiteSpace(adp.Code) ? adp.IdOpeNavigation?.CodeOpe : adp.Code)</td>
                                <td style="font-size: 12px;">@adp.NumDossierAdp</td>
                                <td style="font-size: 12px;">@adp.Logement</td>
                                <td style="font-size: 12px; font-weight: bold;">@(adp.DernierStatutAdp?.DescriptionStatut)</td>
                                <td style="font-size: 12px;">@adp.Client</td>                                 
                                <td style="font-size: 12px;">@adp.Fonctions</td>
                                <td style="font-size: 12px;">@adp.Contact</td>
                                <td style="font-size: 12px;">@adp.Adresse</td>
                                <td style="font-size: 12px;">@adp.Annee</td>
                                <td style="font-size: 12px;">@(string.IsNullOrWhiteSpace(adp.Ville) ? adp.IdOpeNavigation?.IdVilleNavigation?.DescriptionVille : adp.Ville)</td>
                                <td style="font-size: 12px;">@(string.IsNullOrWhiteSpace(adp.CommuneQuartier) ? adp.IdOpeNavigation?.DescriptionOpe : adp.CommuneQuartier)</td>
                                <td style="font-size: 12px;">@adp.DateDocument</td> 
                                <td style="font-size: 12px;">
                                    <form method="post" asp-page-handler="View" asp-route-id="@adp.IdAdp" target="_blank">
                                        <button class="btn btn-warning btn-sm">Voir 👁️</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* Methode pour modifier un fichier ADP *@
    <div class="modal fade" id="adpModal" tabindex="-1" aria-labelledby="adpModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="adpModalLabel">Modifier un fichier ADP</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="adpForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="adpId">
                        <input type="hidden" id="deleteFileFlag" name="DeleteFile" value="false">
                        <div class="row mb-2">
                            <div class="col-md-3">
                                <label for="StatutVal" class="form-label">Statut</label>
                                <select name="statutId" class="form-select" id="statutId">
                                    @foreach (var statut in Model.UserAllowedStatuts)
                                    {
                                        <option value="@statut.Value">@statut.Text</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label for="boite" class="form-label required-field">N° Boite</label>
                                <input type="text" name="Boite" id="boite" class="form-control"/>
                            </div>
                            <div class="col-md-3">
                               <label for="Code" class="form-label">Code</label>
                                <select name="IdOpe" id="Code" class="form-select" required>
                                    <option value="" selected disabled>-- Sélectionner un code --</option>
                                    @if (Model.OperationList != null && Model.OperationList.Any())
                                    {
                                        @foreach (var Ope in Model.OperationList)
                                        {
                                            <option value="@Ope.IdOpe" data-operation="@Ope.DescriptionOpe" data-ville="@Ope.IdVilleNavigation?.DescriptionVille">
                                                @Ope.CodeOpe - @Ope.DescriptionOpe -@(Ope.IdVilleNavigation != null ? Ope.IdVilleNavigation.DescriptionVille : "Ville inconnue")
                                            </option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label for="Operation" class="form-label">Opération</label>
                                <input type="text" id="Operation" name="Operation" class="form-control bg-warning" readonly />
                            </div>
                        </div>
                        <div class="row mb-2">
                             <div class="col-md-3">
                                <label for="client" class="form-label required-field">Client</label>
                                <input type="text" name="Client" id="client" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label for="adresse" class="form-label">Adresse</label>
                                <input type="text" name="Adresse" id="adresse" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label for="contact" class="form-label">Contact</label>
                                <input type="text" name="Contact" id="contact" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label for="fonctions" class="form-label">Profession client</label>
                                <input type="text" name="Fonctions" id="fonctions" class="form-control" />
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-md-6">
                                <label for="logement" class="form-label required-field">N° Logement</label>
                                <input type="text" name="Logement" id="logement" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label for="ville" class="form-label">Ville/Commune</label>
                                <input type="text" name="Ville" id="ville" class="form-control bg-warning" readonly />
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-md-6">
                                <label for="document" class="form-label">Description Doc.</label>
                                <input type="text" name="Document" id="document" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label for="annee" class="form-label">Année</label>
                                <input type="text" name="Annee" id="annee" class="form-control" />
                            </div>
                        </div>
                        @* <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="document" class="form-label">Description Doc.</label>
                                <input type="text" name="DocumentEdit" id="documentEdit" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label for="communequartier" class="form-label">Commune/Quartier</label>
                                <input type="text" name="CommuneQuartierEdit" id="communequartierEdit" class="form-control" />
                            </div>
                        </div> *@
                        <div class="row mb-2">
                            <div class="col-md-6">
                                <label for="NumeroDossierAdp" class="form-label">N° Dossier</label>
                                <input type="text" name="NumeroDossierAdp" id="numeroDossierAdp" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label for="datedocument" class="form-label">Date</label>
                                <input type="date" name="DateDocument" id="datedocument" class="form-control" required />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <label for="fichier" class="form-label required-field">Fichier numérisé (PDF)</label>
                                <input type="file" name="Fichier" id="fichier" class="form-control" accept=".pdf"/>
                                <div class="d-flex align-items-center mt-2">
                                    <button type="button" id="deleteCurrentFile" class="btn btn-outline-danger btn-sm p-1 me-2" style="display: none;" title="Supprimer le fichier actuel">
                                        ❌
                                    </button>
                                    <small id="currentFile" class="form-text text-muted"></small>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn text-white" data-bs-dismiss="modal" style="background: #374151;">Annuler</button>
                    <button type="button" class="btn btn-danger" id="deleteadp">Supprimer</button>
                    <button type="button" class="btn text-white" id="saveadp" style="background: linear-gradient(135deg, #10b981 0%, #374151 100%);">Enregistrer</button>
                </div>
            </div>
        </div>
    </div>

    @* Formulaire pour ajouter les nouveaux fichiers *@
    <div class="modal fade" id="ajoutFichierModal" tabindex="-1" aria-labelledby="ajoutFichierModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form method="post" enctype="multipart/form-data" asp-page-handler="UploadFileAdp">
                     @Html.AntiForgeryToken()
                    <div class="modal-header" style="background: ; color:white;">
                        <h5 class="modal-title" id="ajoutFichierModalLabel">Ajouter un fichier ADP</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label for="StatutVal" class="form-label">Statut</label>
                                <select name="statutId" class="form-select" id="statutId">
                                    <option value="1" selected disabled>Nouveau</option>
                                    @foreach (var statut in Model.UserAllowedStatuts)
                                    {
                                        <option value="@statut.Value">@statut.Text</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label for="Boite" class="form-label">N° Boite</label>
                                <input type="text" name="Boite" class="form-control" required />
                            </div>
                            <div class="col-md-3">
                                <label for="Code" class="form-label">Code</label>
                                <select name="IdOpe" id="Code" class="form-select" required>
                                    <option value="" selected disabled>-- Sélectionner un code --</option>
                                    @if (Model.OperationList != null && Model.OperationList.Any())
                                    {
                                        @foreach (var Ope in Model.OperationList)
                                        {
                                            <option value="@Ope.IdOpe" data-operation="@Ope.DescriptionOpe" data-ville="@Ope.IdVilleNavigation?.DescriptionVille">
                                                @Ope.CodeOpe - @Ope.DescriptionOpe -@(Ope.IdVilleNavigation != null ? Ope.IdVilleNavigation.DescriptionVille : "Ville inconnue")
                                            </option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label for="Operation" class="form-label">Opération</label>
                                <input type="text" id="Operation" name="Operation" class="form-control bg-warning" readonly />
                            </div>
                            <div class="col-md-3">
                                <label for="Client" class="form-label">Client</label>
                                <input type="text" name="Client" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label for="Adresse" class="form-label">Adresse</label>
                                <input type="text" name="Adresse" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label for="Contact" class="form-label">Contact</label>
                                <input type="text" name="Contact" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label for="Fonctions" class="form-label">Profession Client</label>
                                <input type="text" name="Fonctions" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label for="Logement" class="form-label">N° Logement</label>
                                <input type="text" name="Logement" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label for="Ville" class="form-label">Ville/Commune</label>
                                <input type="text" id="Ville" name="Ville" class="form-control bg-warning" readonly />
                            </div>
                            <div class="col-md-6">
                                <label for="Annee" class="form-label">Année</label>
                                <input type="text" name="Annee" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label for="Document" class="form-label">Description Doc.</label>
                                <input type="text" name="Document" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label for="NumeroDossierAdp" class="form-label">N° Dossier</label>
                                <input type="text" name="NumeroDossierAdp" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label for="DateDocument" class="form-label">Date Document</label>
                                <input type="date" name="DateDocument" class="form-control" required />
                            </div>
                            <div class="col-md-12">
                                <label for="Fichier" class="form-label">Fichier numérisé (PDF)</label>
                                <input type="file" name="Fichier" class="form-control" accept=".pdf" required />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-success">Enregistrer</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Scripts Bootstrap et JavaScript personnalisé -->
    <script src="~/js/adp.js"></script>
}
