@* Formulaire pour ajouter les nouveaux fichiers *@
<div class="modal fade" id="ajoutFichierModal" tabindex="-1" aria-labelledby="ajoutFichierModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="uploadForm" method="post" enctype="multipart/form-data" asp-page-handler="UploadFileCarte">
                <div class="modal-header" style="background: linear-gradient(135deg, #10b981 0%, #374151 100%); color:white;">
                    <h5 class="modal-title" id="ajoutFichierModalLabel">Ajouter une carte</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="statutVal" class="form-label">Statut</label>
                            <select name="statutId" class="form-select" id="statutId">
                                <option value="" selected disabled>-- Sélectionner un statut --</option>
                                @foreach (var statut in Model.UserAllowedStatuts)
                                {
                                    <option value="@statut.Value">@statut.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="DateCarte" class="form-label">Date</label>
                            <input type="date" name="DateCarte" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label for="Tube" class="form-label">Tube</label>
                            <input type="text" name="Tube" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label for="Code" class="form-label">Code opération</label>
                            <select name="IdOperation" id="Code" class="form-select" required>
                                <option value="" selected disabled>-- Sélectionner un code --</option>
                                @if (Model.OperationList != null && Model.OperationList.Any())
                                {
                                    @foreach (var Ope in Model.OperationList)
                                    {
                                        <option value="@Ope.IdOpe" data-operation="@Ope.DescriptionOpe" data-ville="@Ope.IdVilleNavigation?.DescriptionVille">
                                            @Ope.CodeOpe - @Ope.DescriptionOpe -@(Ope.IdVilleNavigation != null ? Ope.IdVilleNavigation.DescriptionVille : "Ville inconnue")
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="Operation" class="form-label">Operation</label>
                            <input type="text" name="Operation" class="form-control bg-warning" readonly />
                        </div>
                        <div class="col-md-6">
                            <label for="Ville" class="form-label">Ville</label>
                            <input type="text" name="Ville" class="form-control bg-warning" readonly />
                        </div>
                        <div class="col-md-6">
                            <label for="Legende" class="form-label">Legende</label>
                            <input type="text" name="Legende" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="Originalite" class="form-label">Originalite</label>
                            <select name="Originalite" class="form-select">
                                <option value="" selected disabled>-- Sélectionner une originalité --</option>
                                <option value="PAPIER">PAPIER</option>
                                <option value="CALQUE">CALQUE</option>
                                <option value="NEANT">NEANT</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="Echelle" class="form-label">Echelle</label>
                            <input type="text" name="Echelle" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="Cote" class="form-label">Cote</label>
                            <input type="text" name="Cote" class="form-control" />
                        </div>
                        <div class="col-md-12">
                            <label for="Fichier" class="form-label">Fichier numérisé (PDF)</label>
                            <input type="file" name="Fichier" class="form-control" accept=".pdf" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Enregistrer</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Methode pour modifier un fichier carte *@
<div class="modal fade" id="carteModal" tabindex="-1" aria-labelledby="carteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="carteModalLabel">Modifier une carte</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="carteForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="carteId">
                    <input type="hidden" id="deleteFileFlag" name="DeleteFile" value="false">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="editstatutId" class="form-label">Statut</label>
                            <select name="statutId" id="editstatutId" class="form-select" >
                                <option value="" selected disabled>-- Sélectionner un statut --</option>
                                @foreach (var statut in Model.UserAllowedStatuts)
                                {
                                    <option value="@statut.Value">@statut.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="dateCarte" class="form-label required-field">Date d'édition</label>
                            <input type="date" name="DateCarte" id="dateCarte" class="form-control"/>
                        </div>
                        <div class="col-md-6">
                            <label for="tube" class="form-label required-field">Tube</label>
                            <input type="text" name="Tube" id="tube" class="form-control"/>
                        </div>
                        <div class="col-md-6">
                            <label for="Code" class="form-label">Code Opération</label>
                            <select name="IdOperation" id="code" class="form-select" required>
                                <option value="" selected disabled>-- Sélectionner un code --</option>
                                @if (Model.OperationList != null && Model.OperationList.Any())
                                {
                                    @foreach (var Ope in Model.OperationList)
                                    {
                                        <option value="@Ope.IdOpe" data-operation="@Ope.DescriptionOpe" data-ville="@Ope.IdVilleNavigation?.DescriptionVille">
                                            @Ope.CodeOpe - @Ope.DescriptionOpe -@(Ope.IdVilleNavigation != null ? Ope.IdVilleNavigation.DescriptionVille : "Ville inconnue")
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="operation" class="form-label">Opération</label>
                            <input type="text" name="Operation" id="operation" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="ville" class="form-label required-field">Ville</label>
                            <input type="text" name="Ville" id="ville" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="legende" class="form-label">Legende</label>
                            <input type="text" name="Legende" id="legende" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="originalite" class="form-label">Originalite</label>
                             <select name="Originalite" class="form-select" id="originalite">
                                <option value="" selected disabled>-- Sélectionner une originalité --</option>
                                <option value="PAPIER">PAPIER</option>
                                <option value="CALQUE">CALQUE</option>
                                <option value="NEANT">NEANT</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="echelle" class="form-label">Echelle</label>
                            <input type="text" name="Echelle" id="echelle" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="cote" class="form-label">Cote</label>
                            <input type="text" name="Cote" id="cote" class="form-control" />
                        </div>
                         <div class="col-md-12">
                            <label for="fichier" class="form-label required-field">Fichier numérisé (PDF)</label>
                            <input type="file" name="Fichier" id="fichier" class="form-control" accept=".pdf"/>
                            <div class="d-flex align-items-center mt-2">
                                <button type="button" id="deleteCurrentFile" class="btn btn-outline-danger btn-sm p-1 me-2" style="display: none;" title="Supprimer le fichier actuel">
                                    ❌
                                </button>
                                <small id="currentFile" class="form-text text-muted"></small>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn text-white" data-bs-dismiss="modal" style="background: #374151;">Annuler</button>
                <button type="button" class="btn btn-danger" id="deletecarte">Supprimer</button>
                <button type="button" class="btn text-white" id="savecarte" style="background: linear-gradient(135deg, #10b981 0%, #374151 100%);">Enregistrer</button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="~/js/carte.js"></script>
}
