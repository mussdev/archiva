else
{ *@
     @* Afficher la liste de résultats *@
    <div class="filter-container">
        <div style="max-height:60vh; overflow-y:auto;margin-top:20px;">
            <!--<input type="text" id="table-filter" class="form-control" placeholder="Filtrer dans le tableau...">-->
            <div class="filter-input">
                <input type="text" id="table-filter" class="form-control form-control-sm" placeholder="Filtrer par boite, code,n° logement, client, document ou ...">
            </div>
            <div class="filter-stats">
                <span id="filterStats" class="text-muted small">@Model.VplListEnAttenteDeTratement.Count() fichier(s) trouvé(s)</span>
            </div>
            <table class="table mt-1">
                <thead>
                    <tr>
                        <th style="font-size: 12px;"><input type="checkbox" id="selectAllCheckbox" style="cursor: pointer;" /></th>
                        <th style="font-size: 12px;">Document</th>
                        <th style="font-size: 12px;">N° Boite</th>
                        <th style="font-size: 12px;">N° Dossier</th>
                        <th style="font-size: 12px;">Code</th>
                        <th style="font-size: 12px;">N° Logement</th>
                        <th style="font-size: 12px;">Statut</th>
                        <th style="font-size: 12px;">Client</th>
                        <th style="font-size: 12px;">Profession clt.</th>
                        <th style="font-size: 12px;">Tél.</th>
                        <th style="font-size: 12px;">Adresse</th>
                        <th style="font-size: 12px;">Annee</th>
                        <th style="font-size: 12px;">Ville</th>
                        <th style="font-size: 12px;">Opération | Commune</th>
                        <th style="font-size: 12px;">Date doc.</th>
                        <th style="font-size: 12px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vpl in Model.VplListEnAttenteDeTratement)
                    {
                        <tr>
                            <td style="font-size: 12px;"><input type="checkbox" class="rowCheckbox" data-vpl-id="@vpl.IdVpl" style="cursor: pointer;"></td>
                            <td style="font-size: 12px;">
                                <span class="clickable-name" 
                                    data-bs-toggle="modal" 
                                    data-bs-target="#vplModal"
                                    data-vpl-id="@vpl.IdVpl"
                                    data-document="@(string.IsNullOrEmpty(vpl.Document) ? "" : char.ToUpper(vpl.Document[0]) + vpl.Document.Substring(1).ToLower())"
                                    data-contact="@vpl.Contact"
                                    data-datedocument="@vpl.DateDocument"
                                    data-annee="@vpl.Annee"
                                    data-fonctions="@vpl.Fonctions"
                                    data-client="@vpl.Client"
                                    data-code="@vpl.Code"
                                    data-id-ope="@vpl.IdOpe"
                                    data-statut-id="@vpl.DernierStatutVplId"
                                    data-numDossier="@vpl.NumDossierVpl"
                                    data-boite="@vpl.Boite"
                                    data-logement="@vpl.Logement"
                                    data-adresse="@vpl.Adresse"
                                    data-communequartier="@vpl.CommuneQuartier"
                                    data-ville="@vpl.IdOpeNavigation?.IdVilleNavigation?.DescriptionVille"
                                    data-fichier="@(vpl.Lien ??"")">
                                    @(string.IsNullOrEmpty(vpl.Document) ? "" : char.ToUpper(vpl.Document[0]) + vpl.Document.Substring(1).ToLower())
                                </span>
                            </td>
                            <td style="font-size: 12px;">@vpl.Boite</td>
                            <td style="font-size: 12px;">@(!string.IsNullOrWhiteSpace(vpl.NumDossierVpl) ? vpl.NumDossierVpl : "N/A")</td>
                            <td style="font-size: 12px;">@(string.IsNullOrWhiteSpace(vpl.Code) ? vpl.IdOpeNavigation?.CodeOpe : vpl.Code)</td>
                            <td style="font-size: 12px;">@vpl.Logement</td>
                            @* <td style="font-size: 12px; font-weight: bold;">@vpl.DernierStatutVpl?.DescriptionStatut</td> *@
                            <td>
                                @if (vpl.DernierStatutVpl?.DescriptionStatut == "En attente")
                                {
                                    <span class="badge bg-warning text-dark">En attente</span>
                                }else if (vpl.DernierStatutVpl?.DescriptionStatut == "Réjeté")
                                {
                                    <span class="badge bg-danger">Réjeté</span>
                                }
                                else if (vpl.DernierStatutVpl?.DescriptionStatut == "Nouveau")
                                {
                                    <span class="badge bg-info">Nouveau</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@vpl.DernierStatutVpl?.DescriptionStatut</span>
                                }
                            <td style="font-size: 12px;">@vpl.Client</td>
                            <td style="font-size: 12px;">@vpl.Fonctions</td>
                            <td style="font-size: 12px;">@vpl.Contact</td>
                            <td style="font-size: 12px;">@vpl.Adresse</td>
                            <td style="font-size: 12px;">@vpl.Annee</td>
                            <td style="font-size: 12px;">@(string.IsNullOrWhiteSpace(vpl.Ville) ? vpl.IdOpeNavigation?.IdVilleNavigation?.DescriptionVille : vpl.Ville)</td>
                            <td style="font-size: 12px;">@(string.IsNullOrWhiteSpace(vpl.CommuneQuartier) ? vpl.IdOpeNavigation?.DescriptionOpe : vpl.CommuneQuartier)</td>
                            <td style="font-size: 12px;">@vpl.DateDocument</td>
                            <td style="font-size: 12px;">
                                <form method="post" asp-page-handler="View" asp-route-id="@vpl.IdVpl" target="_blank">
                                    <button class="btn btn-warning">👁️ Voir</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
@* } *@

@* Formulaire pour ajouter les nouveaux fichiers *@
<div class="modal fade" id="ajoutFichierModal" tabindex="-1" aria-labelledby="ajoutFichierModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" enctype="multipart/form-data" asp-page-handler="UploadFileVpl">
                <div class="modal-header" style="background: linear-gradient(135deg, #10b981 0%, #374151 100%); color:white;">
                    <h5 class="modal-title" id="ajoutFichierModalLabel">Ajouter un fichier VPL</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label for="StatutVal" class="form-label">Statut</label>
                            <select name="statutId" class="form-select" id="statutId">
                                <option value="1" selected disabled>Nouveau</option>
                                @foreach (var statut in Model.UserAllowedStatuts)
                                {
                                    <option value="@statut.Value">@statut.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="Boite" class="form-label">N° Boite</label>
                            <input type="text" name="Boite" class="form-control" required />
                        </div>
                        <div class="col-md-3">
                            <label for="Code" class="form-label">Code</label>
                            <select name="IdOpe" id="Code" class="form-select" required>
                                <option value="" selected disabled>-- Sélectionner un code --</option>
                                @if (Model.OperationList != null && Model.OperationList.Any())
                                {
                                    @foreach (var Ope in Model.OperationList)
                                    {
                                        <option value="@Ope.IdOpe" data-operation="@Ope.DescriptionOpe" data-ville="@Ope.IdVilleNavigation?.DescriptionVille">
                                            @Ope.CodeOpe - @Ope.DescriptionOpe -@(Ope.IdVilleNavigation != null ? Ope.IdVilleNavigation.DescriptionVille : "Ville inconnue")
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                        @* <div class="col-md-3">
                            <label for="Code" class="form-label">Code</label>
                            <input type="text" name="Code" class="form-control" required />
                        </div> *@
                        <div class="col-md-3">
                            <label for="Operation" class="form-label">Opération</label>
                            <input type="text" id="Operation" name="Operation" class="form-control bg-warning" readonly />
                        </div>
                        <div class="col-md-3">
                            <label for="Client" class="form-label">Client</label>
                            <input type="text" name="Client" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label for="Adresse" class="form-label">Adresse</label>
                            <input type="text" name="Adresse" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label for="Contact" class="form-label">Contact</label>
                            <input type="text" name="Contact" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label for="Fonctions" class="form-label">Profession client</label>
                            <input type="text" name="Fonctions" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="Logement" class="form-label">N° Logement</label>
                            <input type="text" name="Logement" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="Ville" class="form-label">Ville</label>
                            <input type="text" name="Ville" id="Ville" class="form-control bg-warning" readonly/>
                        </div>
                        <div class="col-md-6">
                            <label for="Annee" class="form-label">Année</label>
                            <input type="text" name="Annee" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="Document" class="form-label">Description Doc.</label>
                            <input type="text" name="Document" class="form-control" />
                        </div>
                        @* <div class="col-md-6">
                            <label for="CommuneQuartier" class="form-label">Commune/Quartier</label>
                            <input type="text" name="CommuneQuartier" class="form-control" />
                        </div> *@
                        <div class="col-md-6">
                            <label for="NumeroDossierVpl" class="form-label">N° Dossier</label>
                            <input type="text" name="NumeroDossierVpl" id="numeroDossierVpl" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="DateDocument" class="form-label">Date Document</label>
                            <input type="date" name="DateDocument" class="form-control" required />
                        </div>
                        <div class="col-md-12">
                            <label for="Fichier" class="form-label">Fichier numérisé (PDF)</label>
                            <input type="file" name="Fichier" class="form-control" accept=".pdf" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Enregistrer</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Methode pour modifier un fichier ADP *@
