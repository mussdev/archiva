    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="vplModalLabel">Modifier un fichier VPL</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="vplForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="vplId">
                    <input type="hidden" id="deleteFileFlag" name="DeleteFile" value="false">
                    <div class="row mb-3">
                        <div class="col-md-3">
