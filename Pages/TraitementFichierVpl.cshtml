@page
@model MyApp.Namespace.TraitementFichierVplModel
@{
    ViewData["Title"] = "Traitement Fichier VPL";
}


@section Styles {
    <link rel="stylesheet" href="~/css/vpl.css"/>  
    
}

<!-- Afficher les messages de succès -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Afficher les messages d'erreur de validation -->
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex align-items-center">
    <h3>Centre de traitement VPL 📚</h3>
    <div class="dropdown">
        <button class="btn btn-secondary dropdown-toggle" type="button" 
                id="actionsDropdown" 
                data-bs-toggle="dropdown" 
                aria-expanded="false">
            Actions
        </button>
        <ul class="dropdown-menu" aria-labelledby="actionsDropdown">
            <li><a class="dropdown-item" href="#" id="exportSelected">Télécharger la sélection</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="#" id="deleteSelected">Supprimer la sélection</a></li>
        </ul>
    </div>
    <div class="ms-auto d-flex gap-2">
        <a class="text-white ms-auto underline btn" 
            id="validateSelected"
            style="background: linear-gradient(135deg, #44f409 0%, #374151 100%);">
            Valider les fichiers
        </a>
        <a class="text-white ms-auto underline btn" 
            id="rejectSelected"
            style="background: linear-gradient(135deg, #eb2b12 0%, #374151 100%);">
            Rejeter les fichiers
        </a>
        @if(User.IsInRole("Administrateur"))
        {
            <button type="button" class="btn text-white ms-auto" data-bs-toggle="modal" data-bs-target="#ajoutFichierModal"
                    style="background: linear-gradient(135deg, #12ecf0 0%, #374151 100%);">
                Indexer un fichier
            </button>
        }      
    </div>
</div>

