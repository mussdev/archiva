                                        <option value="@Ope.IdOpe" data-operation="@Ope.DescriptionOpe" data-ville="@Ope.IdVilleNavigation?.DescriptionVille">
                                            @Ope.CodeOpe - @Ope.DescriptionOpe -@(Ope.IdVilleNavigation != null ? Ope.IdVilleNavigation.DescriptionVille : "Ville inconnue")
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="Operation" class="form-label">Opération</label>
                            <input type="text" id="Operation" name="Operation" class="form-control bg-warning" readonly />
                        </div>
                       @*  <div class="col-md-3">
                            <label for="code" class="form-label required-field">Code</label>
                            <input type="text" name="Code" id="code" class="form-control"/>
                        </div> *@
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label for="client" class="form-label required-field">Client</label>
                            <input type="text" name="Client" id="client" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label for="adresse" class="form-label">Adresse</label>
