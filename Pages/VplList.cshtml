@page
@model anahged.Pages.VplListModel
@{
    ViewData["Title"] = "Liste Vpl 📚";
}
@section Styles {
    <style>
        /* Style pour le modale */
        .clickable-name {
            color: #10b981;
            text-decoration: none;
            cursor: pointer;
            font-weight: 500;
        }
        .clickable-name:hover {
            color: #0d9669;
            text-decoration: underline;
        }
        .modal-header {
            background: linear-gradient(135deg, #10b981 0%, #374151 100%);
            color: white;
        }
        .required-field::after {
            content: "*";
            color: red;
            margin-left: 4px;
        }

        /* Style pour les cases à cocher */
        #selectAllCheckbox {
            transform: scale(1.2);
            margin: 0;
        }

        .rowCheckbox {
            transform: scale(1.1);
            margin: 0;
        }
        
        /* Alignement vertical */
        th:first-child, td:first-child {
            text-align: center;
            vertical-align: middle;
            width: 40px;
        }
    </style>
}


<!-- Afficher les messages de succès -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Afficher les messages d'erreur de validation -->
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex align-items-center">
    <h3>VPL 📚</h3>
    <div class="dropdown">
        <button class="btn btn-secondary dropdown-toggle" type="button" 
                id="actionsDropdown" 
                data-bs-toggle="dropdown" 
                aria-expanded="false">
            Actions
        </button>
        <ul class="dropdown-menu" aria-labelledby="actionsDropdown">
            <li><a class="dropdown-item" href="#" id="exportSelected">Télécharger la sélection</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="#" id="deleteSelected">Supprimer la sélection</a></li>
        </ul>
    </div>
    <span class="ms-auto">
        @if(User.IsInRole("Administrateur"))
        {
            <button type="button" class="btn text-white ms-auto" data-bs-toggle="modal" data-bs-target="#ajoutFichierModal"
                    style="background: linear-gradient(135deg, #10b981 0%, #374151 100%);">
                Ajouter un fichier
            </button>
        }      
    </span>
</div>
<form method="get" class="mt-3 mb-3">
    <div class="row g-2" style="border-bottom: 5px solid #ccc; padding-bottom:10px;">
        <div class="col">
            <input type="text" name="boite" class="form-control" placeholder="Boite">
        </div>
        <div class="col">
            <input type="text" name="code" class="form-control" placeholder="Code">
        </div>
        <div class="col">
            <input type="text" name="logement" class="form-control" placeholder="N° Logement">
        </div>
        <div class="col">
            <input type="text" name="client" class="form-control" placeholder="Client">
        </div> 
        <div class="col">
            <input type="text" name="document" class="form-control" placeholder="Document">
        </div>
        <div class="col">
            <input type="text" name="annee" class="form-control" placeholder="Annee">
        </div>  
        <div class="col-auto">
            <button type="submit" class="btn text-white" style="background: linear-gradient(135deg, #10b981 0%, #374151 100%);">Rechercher</button>
        </div>
    </div>
</form>

@if (ViewData["MessageRechercheVpl"] != null)
{
    <p style="text-align: center; color:red">@ViewData["MessageRechercheVpl"]</p>
}
else
{
    // Afficher la liste de résultats
    <div class="filter-container">
        <div style="max-height:60vh; overflow-y:auto;margin-top:20px;">
            <!--<input type="text" id="table-filter" class="form-control" placeholder="Filtrer dans le tableau...">-->
            <div class="filter-input">
                <input type="text" id="table-filter" class="form-control form-control-sm" placeholder="Filtrer par boite, code,n° logement, client, document ou ...">
            </div>
            <div class="filter-stats">
                <span id="filterStats" class="text-muted small">@Model.VplList.Count() fichier(s) trouvé(s)</span>
            </div>
            <table class="table mt-1">
                <thead>
                    <tr>
                        <th style="font-size: 12px;"><input type="checkbox" id="selectAllCheckbox" style="cursor: pointer;" /></th>
                        <th style="font-size: 12px;">Document</th>
                        <th style="font-size: 12px;">N° Boite</th>
                        <th style="font-size: 12px;">Code</th>
                        <th style="font-size: 12px;">N° Logement</th>
                        <th style="font-size: 12px;">Client</th>
                        <th style="font-size: 12px;">Fonction</th>
                        <th style="font-size: 12px;">Tél.</th>
                        <th style="font-size: 12px;">Adresse</th>
                        <th style="font-size: 12px;">Annee</th>
                        <th style="font-size: 12px;">Ville</th>
                        <th style="font-size: 12px;">Commune/Ville</th>
                        <th style="font-size: 12px;">Date doc.</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vpl in Model.VplList)
                    {
                        <tr>
                            <td style="font-size: 12px;"><input type="checkbox" class="rowCheckbox" data-vpl-id="@vpl.IdVpl" style="cursor: pointer;"></td>
                            <td style="font-size: 12px;">
                                <span class="clickable-name" 
                                    data-bs-toggle="modal" 
                                    data-bs-target="#vplModal"
                                    data-vpl-id="@vpl.IdVpl"
                                    data-document="@(string.IsNullOrEmpty(vpl.Document) ? "" : char.ToUpper(vpl.Document[0]) + vpl.Document.Substring(1).ToLower())"
                                    data-contact="@vpl.Contact"
                                    data-datedocument="@vpl.DateDocument"
                                    data-annee="@vpl.Annee"
                                    data-fonctions="@vpl.Fonctions"
                                    data-client="@vpl.Client"
                                    data-code="@vpl.Code"
                                    data-boite="@vpl.Boite"
                                    data-logement="@vpl.Logement"
                                    data-adresse="@vpl.Adresse"
                                    data-communequartier="@vpl.CommuneQuartier"
                                    data-ville="@vpl.Ville"
                                    data-fichier="@(vpl.Lien ??"")">
                                    @(string.IsNullOrEmpty(vpl.Document) ? "" : char.ToUpper(vpl.Document[0]) + vpl.Document.Substring(1).ToLower())
                                </span>
                            </td>
                            <td style="font-size: 12px;">@vpl.Boite</td>
                            <td style="font-size: 12px;">@vpl.Code</td>
                            <td style="font-size: 12px;">@vpl.Logement</td>
                            <td style="font-size: 12px;">@vpl.Client</td>
                            <td style="font-size: 12px;">@vpl.Fonctions</td>
                            <td style="font-size: 12px;">@vpl.Contact</td>
                            <td style="font-size: 12px;">@vpl.Adresse</td>
                            <td style="font-size: 12px;">@vpl.Annee</td>
                            <td style="font-size: 12px;">@vpl.Ville</td>
                            <td style="font-size: 12px;">@vpl.CommuneQuartier</td>
                            <td style="font-size: 12px;">@vpl.DateDocument</td>
                            <td style="font-size: 12px;">
                                <form method="post" asp-page-handler="View" asp-route-id="@vpl.IdVpl" target="_blank">
                                    <button class="btn btn-warning">Voir 📖</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* Formulaire pour ajouter les nouveaux fichiers *@
